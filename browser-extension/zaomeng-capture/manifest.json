{
  "manifest_version": 3,
  "name": "造梦AI 全网采图助手",
  "version": "0.1.4",
  "description": "支持全网图片右键保存到造梦AI素材库，也保留大图悬浮采集按钮作为辅助。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "造梦AI 全网采图助手",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["taobao-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5000/*"
      ],
      "js": ["site-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
